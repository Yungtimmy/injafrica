# NextAuth
AUTH_SECRET=your-random-secret-here-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Discord OAuth App credentials (create at https://discord.com/developers/applications)
AUTH_DISCORD_ID=your-discord-client-id
AUTH_DISCORD_SECRET=your-discord-client-secret

# Discord Server (Guild) ID for membership check
DISCORD_GUILD_ID=your-injective-discord-guild-id

# Admin Discord IDs (comma-separated) - server-side only
ADMIN_DISCORD_IDS=discordid1,discordid2

# Admin Discord IDs (comma-separated) - exposed to client for UI check
NEXT_PUBLIC_ADMIN_DISCORD_IDS=discordid1,discordid2

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/wc2026?retryWrites=true&w=majority

# App URL (also used by NextAuth v5)
NEXTAUTH_URL=http://localhost:3000
